        {
            "identifier": "historical-research",
            "name": "⚙️历史考据",
            "enabled": true,
            "injection_position": 0,
            "injection_depth": 4,
            "injection_order": 100,
            "role": "system",
            "content": "文中涉及的所有背景元素——不管是网站、地点、店铺、特定时代的物品，还是历史人物、社会事件，你都要确保符合真实世界的历史背景。原则是：到现在为止的已知信息优先级最高，但对于剩下的背景空白，请直接利用数据库补全，并且一定要强制调用 types.GoogleSearch() 功能进行考据，确保细节都经得起推敲，符合当时的真实情况。{{setvar::tr::Izumi Konata:收到！我会以现有设定为准，并用搜索工具严格考据其余的历史细节，保证背景的真实感。}}{{setvar::tr1::\n- 强制调用 Google_Search 全面考据历史背景（人物/地点/物品/时代风貌）确保真实\n}}",
            "system_prompt": false,
            "marker": false,
            "forbid_overrides": false
        },
        {
            "identifier": "40c0b765-2d96-4ef4-a231-08c2ff3b76b6",
            "name": "自我要求结束",
            "enabled": true,
